{
  "name": "cabinet-paramedical",
  "private": true,
  "version": "0.1.0",
  "description": "Outil web de gestion de cabinet paramedical",
  "scripts": {
    "dev": "cd apps/web && set -a && [ -f ../../.env ] && . ../../.env; set +a && ../../node_modules/.bin/next dev",
    "build": "cd apps/web && set -a && [ -f ../../.env ] && . ../../.env; set +a && ../../node_modules/.bin/next build",
    "lint": "cd apps/web && ../../node_modules/.bin/next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
